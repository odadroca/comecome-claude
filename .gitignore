# Never commit ANY database file, anywhere in the tree. This repo holds
# special-category children's health data and `main` auto-deploys, so a stray DB
# (e.g. a live-usage backup dropped in the repo) must never be stageable by accident.
*.db
*.sqlite
*.sqlite3
# SQLite sidecars — WAL/SHM/rollback-journal can each hold DB contents
# (covers *.db-wal/-shm/-journal, *.sqlite-wal/-shm/-journal, *.sqlite3-* etc.):
*.db-*
*.sqlite-*
*.sqlite3-*
# (the app's own DB lives in db/ and was already covered:)
db/*.db
db/*.db-wal
db/*.db-shm

# Per-deployment local overrides (DB path above docroot, secrets) — never commit
config.local.php

# Sprint security Phase 4 — field-encryption key container. The REAL key file is
# never committed (the .example template IS tracked). Match the recommended name
# and any *-key.php container so a stray in-tree copy can't be pushed by accident.
encryption-key.php
*-encryption-key.php
*.key

# Design-system handover (Claude design export: zips + React UI-kit mockups).
# Reference material, not part of the app build — kept on disk, out of the repo.
design-handover/

# subagent-driven-development scratch (briefs, reports, progress, review diffs)
.superpowers/
