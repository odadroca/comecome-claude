# VCS / tooling
.git
.github
.gitignore
.dockerignore
.claude
.remember

# Dev-only (not needed at runtime). Legal files (LICENSE/NOTICE/DISCLAIMER.md)
# are intentionally NOT excluded — they must ship in the artifact.
tests
design-handover
software-launcher-framework
node_modules

# Databases + secrets must NEVER enter the image (the DB lives in the /data volume).
# Mirror the hardened .gitignore: any .db/.sqlite + WAL/SHM/journal sidecars + backups.
# NOTE: .dockerignore globs are NOT recursive like .gitignore — a bare `*.db` matches only
# the context ROOT, so the default db/data.db (a subdirectory) would slip through `COPY .`.
# Use `**/` to exclude at EVERY depth. A17 Part 2 publishes this image, so this is airtight.
**/*.db
**/*.sqlite
**/*.sqlite3
**/*.db-*
**/*.sqlite-*
**/*.sqlite3-*
**/config.local.php
**/*encryption-key.php
**/*.key

# Scratch
_*.md
