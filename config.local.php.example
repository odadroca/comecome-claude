<?php
/**
 * config.local.php.example — per-deployment overrides TEMPLATE.
 *
 * HOW TO USE: copy this file to "config.local.php" (same folder as config.php) and edit.
 * config.local.php is git-ignored, so host-specific values never enter source control.
 * It is loaded by config.php BEFORE its own define()s, so anything you define here wins.
 *
 * A fresh install needs NONE of this — leave it absent and the app runs zero-config
 * with the database at db/data.db. These overrides are OPTIONAL production hardening.
 */

/* -------------------------------------------------------------------------
 * Keep the SQLite database OUTSIDE the web root (recommended for production)
 * so the .db file can never be served over HTTP.
 * ---------------------------------------------------------------------- */

// Most reliable on shared hosting (e.g. Hostinger). Use YOUR absolute path:
// define('DB_PATH', '/home/uXXXXXXXX/private/data.db');

// Or, if config.php sits directly in public_html, this relative form needs no
// hardcoded path — dirname(__DIR__) is the folder ABOVE public_html:
// define('DB_PATH', dirname(__DIR__) . '/private/data.db');

/* -------------------------------------------------------------------------
 * Field-encryption KEY container (Sprint security Phase 4) — OPTIONAL.
 *
 * Point this at the 32-byte base64 key file generated by scripts/gen-key.php,
 * kept ABOVE public_html at chmod 0400. With this UNSET, field encryption stays
 * OFF and the app runs zero-config in plaintext — so leave it commented out
 * unless you have generated a key and want Phase 5 at-rest field encryption on.
 *
 * The key file must NEVER live in the web root and must NEVER be backed up in the
 * same archive as the database.
 * ---------------------------------------------------------------------- */

// define('ENCRYPTION_KEY_FILE', '/home/uXXXXXXXX/private/encryption-key.php');
// Or, relative to a config.php that sits in public_html:
// define('ENCRYPTION_KEY_FILE', dirname(__DIR__) . '/private/encryption-key.php');

// REQUIREMENT for field encryption: the PHP `sodium` extension must be loaded
// (bundled with PHP 7.2+; on shared hosting enable `extension=sodium` in the host's
// php.ini). Verify on your host with:   php -m | grep sodium
// If a key is configured but sodium is MISSING, the app FAILS CLOSED (it refuses to
// write plaintext under a configured key) rather than silently storing plaintext.

/* -------------------------------------------------------------------------
 * Database BACKUP directory (Sprint security Phase 5 cheap win) — OPTIONAL.
 *
 * backupDatabase() writes a full copy of the SQLite DB. By default it lands in the
 * in-tree db/ folder (zero-config). For production, point it ABOVE public_html so a
 * plaintext DB copy is never inside the served tree (the .htaccess deny evaporates
 * under nginx/litespeed). Then sync those backups OFF-HOST, ENCRYPTED (age/gpg), and
 * NEVER in the same archive as the encryption key file.
 * ---------------------------------------------------------------------- */

// define('BACKUP_DIR', '/home/uXXXXXXXX/private/backups');
// Or, relative to a config.php that sits in public_html:
// define('BACKUP_DIR', dirname(__DIR__) . '/private/backups');

/* -------------------------------------------------------------------------
 * Tip: for the strongest separation, put your secrets in a PHP file ABOVE the
 * web root and point the COMECOME_CONFIG env var at it (e.g. in .htaccess:
 * `SetEnv COMECOME_CONFIG /home/uXXXXXXXX/private/comecome-config.php`). config.php
 * loads that file too — and because it is outside public_html it can never be
 * served. This config.local.php still works, but it lives inside the web root.
 * ---------------------------------------------------------------------- */
